root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# YAML requires 2-space indentation.
[*.{yml,yaml}]
indent_size = 2

# Trailing whitespace can be a hard line break in Markdown.
[*.md]
trim_trailing_whitespace = false
